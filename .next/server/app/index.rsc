16:{"metadata":[["$","title","0",{"children":"Roman Castro"}],["$","meta","1",{"name":"description","content":"Portafolio de Román Castro, desarrollador Front-End especializado en React, NextJS y Firebase. Me apasiona crear soluciones digitales intuitivas y eficientes, enfocadas en diseño responsivo y experiencia de usuario. Mi objetivo es contribuir con creatividad y optimización para impulsar proyectos innovadores que generen impacto real. Busco crecer profesionalmente desarrollando productos que mejoren la interacción entre usuarios y tecnología. "}],["$","meta","2",{"property":"og:title","content":"Roman Castro – Portfolio"}],["$","meta","3",{"property":"og:description","content":"Mi portafolio como desarrollador web."}],["$","meta","4",{"property":"og:url","content":"https://rromancastro.vercel.app/"}],["$","meta","5",{"property":"og:site_name","content":"Roman Castro"}],["$","meta","6",{"property":"og:locale","content":"es_AR"}],["$","meta","7",{"property":"og:image","content":"https://rromancastro.vercel.app/og-image.png"}],["$","meta","8",{"property":"og:image:width","content":"1200"}],["$","meta","9",{"property":"og:image:height","content":"630"}],["$","meta","10",{"property":"og:image:alt","content":"Vista previa del portafolio de Roman Castro"}],["$","meta","11",{"property":"og:type","content":"website"}],["$","meta","12",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","13",{"name":"twitter:title","content":"Roman Castro – Portfolio"}],["$","meta","14",{"name":"twitter:description","content":"Mi portafolio como desarrollador web."}],["$","meta","15",{"name":"twitter:image","content":"https://rromancastro.vercel.app/og-image.png"}],["$","link","16",{"rel":"icon","href":"/favicon.ico?favicon.ca281702.ico","sizes":"154x154","type":"image/x-icon"}],["$","$L1c","17",{}]],"error":null,"digest":"$undefined"}
